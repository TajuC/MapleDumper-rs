import { Button, LineEdit, StandardTableView, VerticalBox, HorizontalBox, GroupBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "MapleDumper";
    preferred-width: 760px;
    preferred-height: 540px;
    min-width: 560px;
    min-height: 400px;

    in-out property <string> process: "MapleStory.exe";
    in-out property <string> module;
    in-out property <string> patterns: "patterns.txt";
    in-out property <string> status: "Idle";
    in-out property <[[StandardListViewItem]]> rows;

    callback scan();
    callback save-offsets();
    callback save-update();

    VerticalBox {
        GroupBox {
            title: "Target";
            VerticalBox {
                HorizontalBox {
                    LineEdit {
                        placeholder-text: "process name (e.g. MapleStory.exe)";
                        text <=> root.process;
                    }
                    LineEdit {
                        placeholder-text: "module (optional, defaults to process)";
                        text <=> root.module;
                    }
                }
                HorizontalBox {
                    LineEdit {
                        placeholder-text: "patterns file";
                        text <=> root.patterns;
                    }
                    Button {
                        text: "Scan";
                        primary: true;
                        clicked => {
                            root.scan();
                        }
                    }
                }
            }
        }

        Text {
            text: root.status;
        }

        StandardTableView {
            columns: [
                { title: "Symbol" },
                { title: "Category" },
                { title: "Value" },
            ];
            rows: root.rows;
        }

        HorizontalBox {
            Button {
                text: "Save offsets.h";
                clicked => {
                    root.save-offsets();
                }
            }
            Button {
                text: "Save update.txt";
                clicked => {
                    root.save-update();
                }
            }
        }
    }
}
